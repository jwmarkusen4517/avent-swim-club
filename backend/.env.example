# ── Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────
# Found at: supabase.com > your project > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ─────────────────────────────────────────────────────────
# Found at: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── JWT ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate-a-random-64-byte-hex-string
JWT_REFRESH_SECRET=generate-a-different-random-64-byte-hex-string

# ── Internal job secret ───────────────────────────────────────────────
# Used to authenticate Render cron job hitting /internal/midnight
INTERNAL_JOB_SECRET=generate-a-random-secret

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://aventswim.club,http://localhost:3000

# ── Club settings ─────────────────────────────────────────────────────
# Timezone for daily workout date calculation
CLUB_TIMEZONE=America/Chicago
